{
  "name": "score68",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Electron desktop app: enumerate dates whose (D + M + ⌊Y/100⌋ + Y%100) % 100 equals a target value.",
  "main": "./out/main/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/al-siv/score68.git"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "package": "electron-builder --publish never",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier -w .",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "verify": "npm run lint && npm run typecheck && npm run test"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "vue": "^3.5.33",
    "vue-i18n": "^11.4.0"
  },
  "devDependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.2.1",
    "eslint-plugin-vue": "^10.9.0",
    "fast-check": "^4.7.0",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^7.3.2",
    "vitest": "^4.1.5",
    "vue-tsc": "^2.2.8",
    "zod": "^4.3.6"
  }
}
